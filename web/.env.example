# ===========================================
# Craftly Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it's gitignored.

# === Site ===
NEXT_PUBLIC_SITE_URL=https://craftlyrobot.com
NEXT_PUBLIC_SITE_NAME=Craftly

# === Analytics (optional — Plausible) ===
# Get these from plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=craftlyrobot.com
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# === Error monitoring (optional — Sentry) ===
# Get this from sentry.io
SENTRY_DSN=

# === Cloudflare Turnstile (bot protection for forms) ===
# Get these from https://dash.cloudflare.com → Turnstile
# Leave empty in development — forms will work without verification
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Email (optional — for sending notifications) ===
# Wire up when backend is ready (Resend, SendGrid, etc.)
EMAIL_FROM=hello@craftlyrobot.com
EMAIL_API_KEY=

# === Database (future — for storing applications) ===
# When you wire up Postgres (Neon, Supabase, etc.)
DATABASE_URL=

# === Upstash Redis (future — for production rate limiting) ===
# The current rate-limit.ts uses in-memory storage.
# For production (multiple instances), use Upstash:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Slack (optional — for team notifications) ===
# Webhook URL for #applications or #contact channel
SLACK_WEBHOOK_URL=
