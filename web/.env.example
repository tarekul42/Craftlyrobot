# ===========================================
# Craftly Environment Variables
# ===========================================
# Copy to .env.local and fill in values.
# NEVER commit .env.local.

# === Site (required) ===
NEXT_PUBLIC_SITE_URL=https://craftlyrobot.com
NEXT_PUBLIC_SITE_NAME=Craftly

# === Analytics (Plausible — optional) ===
# Get from plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=craftlyrobot.com
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# === Error monitoring (Sentry — optional) ===
# Get from sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# === Cloudflare Turnstile (required for production) ===
# Get from https://dash.cloudflare.com → Turnstile
# Leave empty in dev — forms work without verification
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Email (Resend — required for production) ===
# Get from resend.com
RESEND_API_KEY=
EMAIL_FROM=hello@craftlyrobot.com

# === Database (Neon / Supabase / etc — required for production) ===
# Get from your Postgres provider
DATABASE_URL=

# === Slack notifications (optional) ===
# Create incoming webhook in Slack
SLACK_WEBHOOK_URL=

# === Upstash Redis (optional — for production rate limiting) ===
# Current rate-limit.ts uses in-memory storage.
# For production with multiple instances, use Upstash:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
