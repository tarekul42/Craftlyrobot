{
  "name": "craftly-website",
  "private": true,
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "build": "bun run --filter web build",
    "start": "bun run --filter web start",
    "lint": "bun run --filter web lint",
    "typecheck": "bun run --filter web typecheck",
    "test": "bun run --filter web test",
    "test:e2e": "bun run --filter web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,css,json}\"",
    "prepare": "husky",
    "db:generate": "bun run --filter web db:generate",
    "db:push": "bun run --filter web db:push",
    "db:migrate": "bun run --filter web db:migrate",
    "db:studio": "bun run --filter web db:studio"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
